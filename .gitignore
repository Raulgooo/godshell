# ─── Binary ───────────────────────────────────────────────────────────────────
godshell
godshell-*

# ─── Go ───────────────────────────────────────────────────────────────────────
*.test
*.out
/vendor/

# ─── eBPF build artifacts ─────────────────────────────────────────────────────
# Raw clang output in ebpf/ (regenerated by `clang -target bpf`)
ebpf/*.bpf.o


ebpf/vmlinux.h

# ─── Runtime data ─────────────────────────────────────────────────────────────
# SQLite event database written at runtime
*.db
*.db-wal
*.db-shm
/var/

# ─── Config ───────────────────────────────────────────────────────────────────
# Local config overrides (the default is generated on first run)
config.toml

# ─── Dev environment ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
tmp/
