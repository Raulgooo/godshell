# ─── Binary ───────────────────────────────────────────────────────────────────
godshell
godshell-*

# ─── Go ───────────────────────────────────────────────────────────────────────
*.test
*.out
/vendor/

# ─── eBPF build artifacts ─────────────────────────────────────────────────────
# Raw clang output in ebpf/ (regenerated by `clang -target bpf`)
ebpf/*.bpf.o

# bpf2go generated files (bpf_bpfel.go, bpf_bpfeb.go, *.o) ARE committed.
# This keeps the repo buildable with just Go — no clang or bpf2go needed.
# Regenerate with: bpf2go ... if you change observer.bpf.c

# vmlinux header (generated by bpftool, kernel-version specific)
ebpf/vmlinux.h

# ─── Runtime data ─────────────────────────────────────────────────────────────
# SQLite event database written at runtime
*.db
*.db-wal
*.db-shm
/var/

# ─── Config ───────────────────────────────────────────────────────────────────
# Local config overrides (the default is generated on first run)
config.toml

# ─── Dev environment ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
tmp/
