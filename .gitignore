# ─── Binary ───────────────────────────────────────────────────────────────────
godshell
godshell-*

# ─── Go ───────────────────────────────────────────────────────────────────────
*.test
*.out
/vendor/

# ─── eBPF build artifacts ─────────────────────────────────────────────────────
# Compiled BPF bytecode (regenerated by `make ebpf`)
ebpf/*.bpf.o

# bpf2go generated Go bindings (regenerated by `go generate`)
*_bpfel.go
*_bpfeb.go

# vmlinux header (generated by bpftool, kernel-version specific)
ebpf/vmlinux.h

# ─── Runtime data ─────────────────────────────────────────────────────────────
# SQLite event database written at runtime
*.db
*.db-wal
*.db-shm
/var/

# ─── Config ───────────────────────────────────────────────────────────────────
# Local config overrides (the default is generated on first run)
config.toml

# ─── Dev environment ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
tmp/
