[0.116, "o", "\u001b[H\n\n\n \u001b[1;38;2;255;68;68mgodshell❯ \u001b[0m\u001b[38;2;204;204;204mShort-lived outbound connectors were curl PID 259288, systemctl PID 259231, many hyprctl instances, logger\u001b[m          \u001b[K\r\n \u001b[38;2;204;204;204minstances, and earlier systemd-userwork workers. Evidence: summary.recently_exited shows nonzero total_connections with\u001b[m       \u001b[K\r\n \u001b[38;2;204;204;204mshort lifespans.\u001b[0m                                                                                                              \u001b[K\r\n \u001b[38;2;204;204;204m\u001b[0m                                                                                                                              \u001b[K\r\n \u001b[38;2;204;204;204m1. curl PID 259288, lifespan 1.316s, 10 connections.\u001b[0m                                                                          \u001b[K\r\n \u001b[38;2;204;204;204m2. systemctl PID 259231, lifespan 11ms, 1 connection.\u001b[0m                                                                         \u001b[K\r\n \u001b[38;2;204;204;204m3. hyprctl PIDs 259334, 259336, 259331, 259333, 259321, 259323, 259302, 259304, 259226, 259228, 259222, 259224, 259216,\u001b[m       \u001b[K\r\n \u001b[38;2;204;204;204m259221, 259213, 259215, 259186, 259188, 259173, 259175, 259170, 259172, 259167, 259169, 259161, 259163, 259158, 259160,\u001b[m       \u001b[K\r\n \u001b[38;2;204;204;204m259155, 259157, 259149, 259151, 259146, 259148; lifespans 4–13ms, 1 connection each.\u001b[0m                                          \u001b[K\r\n \u001b[38;2;204;204;204m4. logger PIDs 259633, 259549, 259547, 259545, 259543, 259541, 259536, 259534, 259532, 259528, 259526, 259524, 259522,\u001b[m        \u001b[K\r\n \u001b[38;2;204;204;204m259520, 259518, 259513, 259510, 259508, 259506, 259504, 259485, 259483, 259480, 259477, 259343, 259327, 259325; lifespans\u001b[m     \u001b[K\r\n \u001b[38;2;204;204;204m0–3ms, 1 connection each.\u001b[0m                                                                                                     \u001b[K\r\n \u001b[38;2;204;204;204m5. systemd-userwork PIDs 257517, 257518, 257519; lifespan about 5m, 2 connections each. Short-lived relative to daemons, but\u001b[m  \u001b[K\r\n \u001b[38;2;204;204;204mnot burst-short.\u001b[0m                                                                                                              \u001b[K\r\n \u001b[38;2;204;204;204m\u001b[0m                                                                                                                              \u001b[K\r\n \u001b[38;2;204;204;204mI can drill into any of these PIDs’ lineage to tell you what launched them.\u001b[0m                                                   \u001b[K\r\n\n\n\n\n\n\n\n\n\n\n\n \u001b[1;38;2;0;255;136m❯ \u001b[0m\u001b[38;5;240ma\u001b[0m\u001b[38;5;240msk godshell something...\u001b[0m                                                                                                   \u001b[K\r\n \u001b[38;2;85;85;85mCtrl+([r]efresh [s]ave [l]oad [p]anel) type help for more info, Esc to toggle focus\u001b[0m                                           \u001b[K\r\n                                                                                                                               \u001b[K\u001b[J\u001b[33;H"]
