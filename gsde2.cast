[0.306, "o", "\u001b[6A\u001b[12D\u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m            \u001b[1B\r\u001b[1m\u001b[31m}\u001b[1B\u001b[1C\u001b[1m\u001b[31mF\u001b[1B\u001b[0m\u001b[39m\r\u001b[1m\u001b[31mg\u001b[0m\u001b[39m\u001b[39mc\u001b[39mc \u001b[24m/\u001b[24mt\u001b[24mm\u001b[24mp\u001b[24m/\u001b[24mc\u001b[24m2\u001b[24m_\u001b[24ma\u001b[24m\u001b[33mg\u001b[39m\u001b[24me\u001b[24m\u001b[1m\u001b[31mn\u001b[24m\u001b[1m\u001b[31mt\u001b[24m\u001b[1m\u001b[31m.\u001b[0m\u001b[39m\u001b[24mc\u001b[32m \u001b[32m-\u001b[32mo\u001b[39m \u001b[4m/\u001b[4mt\u001b[4mm\u001b[4mp\u001b[4m/\u001b[4mo\u001b[4mb\u001b[4mf\u001b[4m_\u001b[4mt\u001b[4ma\u001b[4mr\u001b[4mg\u001b[4me\u001b[4mt\u001b[24m\u001b[1B\r\u001b[39mm\u001b[39mv\u001b[17C\u001b[32m/\u001b[32mt\u001b[39m\u001b[1B\r\u001b[0m\u001b[39m/\u001b[0m\u001b[39mt\u001b[0m\u001b[39mm\u001b[0m\u001b[39mp\u001b[0m\u001b[39m/\u001b[0m\u001b[39mz\u001b[0m\u001b[39ms\u001b[0m\u001b[39mh\u001b[0m\u001b[39m_\u001b[0m\u001b[39mc\u001b[0m\u001b[39mo\u001b[0m\u001b[39mp\u001b[0m\u001b[39my\u001b[1B\r\u001b[39mr\u001b[39mm \u001b[1m\u001b[31m/\u001b[1m\u001b[31mt\u001b[1m\u001b[31mm\u001b[1m\u001b[31mp\u001b[1m\u001b[31m/\u001b[1m\u001b[31mz\u001b[1m\u001b[31ms\u001b[1m\u001b[31mh\u001b[1m\u001b[31m_\u001b[1m\u001b[31mc\u001b[1m\u001b[31mo\u001b[1m\u001b[31mp\u001b[1m\u001b[31my\u001b[0m\u001b[39m"]
[0.023, "o", "\u001b[5A\r\u001b[0m\u001b[33m}\u001b[39m\u001b[1B\u001b[1C\u001b[1m\u001b[31mF\u001b[0m\u001b[39m\u001b[1B\r\u001b[0m\u001b[32mg\u001b[32mc\u001b[32mc\u001b[39m \u001b[4m/\u001b[4mt\u001b[4mm\u001b[4mp\u001b[4m/\u001b[4mc\u001b[4m2\u001b[4m_\u001b[4ma\u001b[39m\u001b[4mg\u001b[4me\u001b[0m\u001b[39m\u001b[4mn\u001b[0m\u001b[39m\u001b[4mt\u001b[0m\u001b[39m\u001b[4m.\u001b[4mc\u001b[24m\u001b[39m \u001b[39m-\u001b[39mo \u001b[24m/\u001b[24mt\u001b[24mm\u001b[24mp\u001b[24m/\u001b[24mo\u001b[24mb\u001b[24mf\u001b[24m_\u001b[24mt\u001b[24ma\u001b[24mr\u001b[24mg\u001b[24me\u001b[24mt\u001b[1B\r\u001b[32mm\u001b[32mv\u001b[39m\u001b[17C\u001b[39m/\u001b[39mt\u001b[1B\r\u001b[1m\u001b[31m/\u001b[1m\u001b[31mt\u001b[1m\u001b[31mm\u001b[1m\u001b[31mp\u001b[1m\u001b[31m/\u001b[1m\u001b[31mz\u001b[1m\u001b[31ms\u001b[1m\u001b[31mh\u001b[1m\u001b[31m_\u001b[1m\u001b[31mc\u001b[1m\u001b[31mo\u001b[1m\u001b[31mp\u001b[1m\u001b[31my\u001b[0m\u001b[39m\u001b[1B\r\u001b[32mr\u001b[32mm\u001b[39m \u001b[0m\u001b[39m/\u001b[0m\u001b[39mt\u001b[0m\u001b[39mm\u001b[0m\u001b[39mp\u001b[0m\u001b[39m/\u001b[0m\u001b[39mz\u001b[0m\u001b[39ms\u001b[0m\u001b[39mh\u001b[0m\u001b[39m_\u001b[0m\u001b[39mc\u001b[0m\u001b[39mo\u001b[0m\u001b[39mp\u001b[0m\u001b[39my"]
[0.241, "o", "\u001b[15A\b\b\b\u001b[1m\u001b[30mp\u001b[1m\u001b[30mr\u001b[1m\u001b[30mo\u001b[1m\u001b[30mc\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30mq\u001b[1m\u001b[30mu\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30mv\u001b[1m\u001b[30mi\u001b[1m\u001b[30mv\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30m2\u001b[1m\u001b[30m0\u001b[1m\u001b[30m0\u001b[1m\u001b[30mm\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30my\u001b[1m\u001b[30m \u001b[1m\u001b[30mm\u001b[1m\u001b[30mu\u001b[1m\u001b[30me\u001b[1m\u001b[30mr\u001b[1m\u001b[30me\u001b[0m\u001b[39m\u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[1B\r\u001b[1m\u001b[30mb\u001b[1m\u001b[30ma\u001b[1m\u001b[30ms\u001b[0m\u001b[39mh\u001b[32m \u001b[32m-\u001b[24m\u001b[32mc\u001b[39m\u001b[24m \u001b[24m\u001b[33m'\u001b[39m\u001b[24ms\u001b[4ml\u001b[4me\u001b[4me\u001b[4mp\u001b[4m \u001b[4m0\u001b[4m.\u001b[4m2\u001b[4m \u001b[4m&\u001b[4m&\u001b[4m \u001b[39m\u001b[4mc\u001b[39m\u001b[4mu\u001b[4mr\u001b[24m\u001b[39ml\u001b[33m \u001b[33mh\u001b[39m\u001b[39mt\u001b[33mt\u001b[33mps:/\u001b[39m/\u001b[1m\u001b[31mexa\u001b[0m\u001b[39mmple.\u001b[33mco\u001b[39mm\u001b[33m'\u001b[39m &\u001b[1B\r\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[14A\u001b[49C"]
