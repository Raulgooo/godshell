01b[1m\u001b[31mp\u001b[1m\u001b[31mr\u001b[1m\u001b[31mi\u001b[1m\u001b[31mn\u001b[1m\u001b[31mt\u001b[1m\u001b[31m(\u001b[1m\u001b[31m\"\u001b[1m\u001b[31m[\u001b[1m\u001b[31ms\u001b[1m\u001b[31mi\u001b[1m\u001b[31mm\u001b[1m\u001b[31m]\u001b[1m\u001b[31m \u001b[1m\u001b[31mC\u001b[1m\u001b[31mo\u001b[1m\u001b[31mn\u001b[1m\u001b[31mn\u001b[1m\u001b[31me\u001b[1m\u001b[31mc\u001b[1m\u001b[31mt\u001b[1m\u001b[31mi\u001b[1m\u001b[31mo\u001b[1m\u001b[31mn\u001b[1m\u001b[31m \u001b[1m\u001b[31me\u001b[1m\u001b[31ms\u001b[1m\u001b[31mt\u001b[1m\u001b[31ma\u001b[1m\u001b[31mb\u001b[1m\u001b[31ml\u001b[1m\u001b[31mi\u001b[1m\u001b[31ms\u001b[1m\u001b[31mh\u001b[1m\u001b[31me\u001b[1m\u001b[31md\u001b[1m\u001b[31m \u001b[1m\u001b[31mt\u001b[1m\u001b[31mo\u001b[1m\u001b[31m \u001b[1m\u001b[31m1\u001b[1m\u001b[31m.\u001b[1m\u001b[31m1\u001b[1m\u001b[31m.\u001b[1m\u001b[31m1\u001b[1m\u001b[31m.\u001b[1m\u001b[31m1\u001b[1m\u001b[31m:\u001b[1m\u001b[31m4\u001b[1m\u001b[31m4\u001b[1m\u001b[31m3\u001b[1m\u001b[31m\"\u001b[1m\u001b[31m)\u001b[0m\u001b[39m\u001b[1B\u001b[52D\u001b[1m\u001b[31ms\u001b[1m\u001b[31m.\u001b[1m\u001b[31mc\u001b[1m\u001b[31ml\u001b[1m\u001b[31mo\u001b[1m\u001b[31ms\u001b[1m\u001b[31me\u001b[0m\u001b[39m\u001b[33m(\u001b[33m)\u001b[39m\u001b[1B\r\u001b[1m\u001b[31me\u001b[1m\u001b[31mx\u001b[1m\u001b[31mc\u001b[1m\u001b[31me\u001b[1m\u001b[31mp\u001b[1m\u001b[31mt\u001b[0m\u001b[39m\u001b[1B\b\b\u001b[1m\u001b[31mp\u001b[1m\u001b[31mr\u001b[1m\u001b[31mi\u001b[1m\u001b[31mn\u001b[1m\u001b[31mt\u001b[1m\u001b[31m(\u001b[1m\u001b[31mf\u001b[1m\u001b[31m\"\u001b[1m\u001b[31m[\u001b[1m\u001b[31ms\u001b[1m\u001b[31mi\u001b[1m\u001b[31mm\u001b[1m\u001b[31m]\u001b[1m\u001b[31m \u001b[1m\u001b[31mC\u001b[1m\u001b[31mo\u001b[1m\u001b[31mn\u001b[1m\u001b[31mn\u001b[1m\u001b[31me\u001b[1m\u001b[31mc\u001b[1m\u001b[31mt\u001b[1m\u001b[31mi\u001b[1m\u001b[31mo\u001b[1m\u001b[31mn\u001b[1m\u001b[31m \u001b[1m\u001b[31ma\u001b[1m\u001b[31mt\u001b[1m\u001b[31mt\u001b[1