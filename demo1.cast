[2.408, "o", "# Simula un exfiltrador de credenciales en Python\r\r\ncat > /tmp/exfil_sim.py << 'EOF'\u001b[K\r\r\nimport time, socket, os\u001b[K\r\r\n\u001b[K\r\r\n# Paso 1: Lee la llave privada SSH (simula acceso a credenciales)\u001b[K\r\r\ntry:\u001b[K\r\r\n    with open(os.path.expanduser(\"~/.ssh/id_rsa\"), \"r\") as f:\u001b[K\r\r\n        data = f.read(128)  # Solo los primeros bytes\u001b[K\r\r\n        print(f\"[sim] Read {len(data)} bytes from id_rsa\")\u001b[K\r\r\nexcept FileNotFoundError:\u001b[K\r\r\n    # Si no tienes llave SSH, lee algo equivalentemente sensible\u001b[K\r\r\n    with open(os.path.expanduser(\"~/.config/google-chrome/Default/Cookies\"), \"rb\") as f:\u001b[K\r\r\n        data = f.read(128)\u001b[K\r\r\n        print(f\"[sim] Read {len(data)} bytes from Chrome cookies\")\u001b[K\r\r\n\u001b[K\r\r\ntime.sleep(1)\u001b[K\r\r\n\u001b[K\r\r\n# Paso 2: Abre una conexión TCP externa (simula exfiltración)\u001b[K\r\r\ntry:\u001b[K\r\r\n    s = socket.create_connection((\"1.1.1.1\", 443), timeout=3)\u001b[K\r\r\n    print(\"[sim] Connection established to 1.1.1.1:443\")\u001b[K\r\r\n    s.close()\u001b[K\r\r\nexcept Exception as e:\u001b[K\r\r\n    print(f\"[sim] Connection attempt: {e}\")\u001b[K\r\r\n\u001b[K\r\r\nprint(\"[sim] Exfil simulation complete. Sleeping...\")\u001b[K\r\r\ntime.sleep(30)  # Mantiene el proceso vivo para que Godshell lo capture\u001b[K\r\r\nEOF\u001b[K\r\r\n\u001b[K\r\r\npython3 /tmp/exfil_sim.py &\u001b[K"]
[0.058, "o", "\u001b[29A\u001b[16D\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mi\u001b[1m\u001b[30mm\u001b[1m\u001b[30mu\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30mu\u001b[1m\u001b[30mn\u001b[1m\u001b[30m \u001b[1m\u001b[30me\u001b[1m\u001b[30mx\u001b[1m\u001b[30mf\u001b[1m\u001b[30mi\u001b[1m\u001b[30ml\u001b[1m\u001b[30mt\u001b[1m\u001b[30mr\u001b[1m\u001b[30ma\u001b[1m\u001b[30md\u001b[1m\u001b[30mo\u001b[1m\u001b[30mr\u001b[1m\u001b[30m \u001b[1m\u001b[30md\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30mr\u001b[1m\u001b[30me\u001b[1m\u001b[30md\u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30mc\u001b[1m\u001b[30mi\u001b[1m\u001b[30ma\u001b[1m\u001b[30ml\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30m \u001b[1m\u001b[30mP\u001b[1m\u001b[30my\u001b[1m\u001b[30mt\u001b[1m\u001b[30mh\u001b[1m\u001b[30mo\u001b[1m\u001b[30mn\u001b[0m\u001b[39m\u001b[1B\r\u001b[32mc\u001b[32ma\u001b[32mt\u001b[39m \u001b[33m>\u001b[39m \u001b[4m/\u001b[4mt\u001b[4mm\u001b[4mp\u001b[4m/\u001b[4me\u001b[4mx\u001b[4mf\u001b[4mi\u001b[4ml\u001b[4m_\u001b[4ms\u001b[4mi\u001b[4mm\u001b[4m.\u001b[4mp\u001b[4my\u001b[24m \u001b[33m<\u001b[33m<\u001b[39m \u001b[33m'\u001b[33mE\u001b[33mO\u001b[33mF\u001b[33m'\u001b[39m\u001b[1B\r\u001b[32mi\u001b[32mm\u001b[32mp\u001b[32mo\u001b[32mr\u001b[32mt\u001b[39m\u001b[2B\r\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mP\u001b[1m\u001b[30ma\u001b[1m\u001b[30ms\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30m1\u001b[1m\u001b[30m:\u001b[1m\u001b[30m \u001b[1m\u001b[30mL\u001b[1m\u001b[30me\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30mv\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30mp\u001b[1m\u001b[30mr\u001b[1m\u00