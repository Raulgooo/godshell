[0.029, "o", "\u001b[1m\u001b[30ma\u001b[1m\u001b[30ms\u001b[1m\u001b[30mc\u001b[1m\u001b[30mi\u001b[1m\u001b[30mi\u001b[1m\u001b[30mn\u001b[1m\u001b[30me\u001b[1m\u001b[30mm\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30mu\u001b[1m\u001b[30mp\u001b[1m\u001b[30ml\u001b[1m\u001b[30mo\u001b[1m\u001b[30ma\u001b[1m\u001b[30md\u001b[1m\u001b[30m \u001b[1m\u001b[30md\u001b[1m\u001b[30me\u001b[1m\u001b[30mm\u001b[1m\u001b[30mo\u001b[1m\u001b[30m1\u001b[1m\u001b[30m.\u001b[1m\u001b[30mc\u001b[1m\u001b[30ma\u001b[1m\u001b[30ms\u001b[1m\u001b[30mt\u001b[0m\u001b[39m\u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[0m\u001b[39m \u001b[1B\r\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[1B\u001b[K\u001b[29A\u001b[38C"]
[0.005, "o", "\u001b[27D\u001b[0m\u001b[32ma\u001b[0m\u001b[32ms\u001b[0m\u001b[32mc\u001b[0m\u001b[32mi\u001b[0m\u001b[32mi\u001b[0m\u001b[32mn\u001b[0m\u001b[32me\u001b[0m\u001b[32mm\u001b[0m\u001b[32ma\u001b[39m\u001b[0m\u001b[39m \u001b[0m\u001b[39mu\u001b[0m\u001b[39mp\u001b[0m\u001b[39ml\u001b[0m\u001b[39mo\u001b[0m\u001b[39ma\u001b[0m\u001b[39md\u001b[0m\u001b[39m \u001b[0m\u001b[39m\u001b[4md\u001b[0m\u001b[39m\u001b[4me\u001b[0m\u001b[39m\u001b[4mm\u001b[0m\u001b[39m\u001b[4mo\u001b[0m\u001b[39m\u001b[4m1\u001b[0m\u001b[39m\u001b[4m.\u001b[0m\u001b[39m\u001b[4mc\u001b[0m\u001b[39m\u001b[4ma\u001b[0m\u001b[39m\u001b[4ms\u001b[0m\u001b[39m\u001b[4mt\u001b[24m"]
[0.023, "o", "\u001b[27D\u001b[32m#\u001b[32m \u001b[32mS\u001b[32mi\u001b[32mm\u001b[32mu\u001b[32ml\u001b[32ma\u001b[32m \u001b[39mun exfil\u001b[4mt\u001b[4mr\u001b[4ma\u001b[4md\u001b[4mo\u001b[4mr\u001b[4m \u001b[4md\u001b[4me\u001b[4m \u001b[24mcredenciales en Python\u001b[1B\rcat > /tmp/exfil_sim.py << 'EOF'\u001b[K\u001b[1B\rimport time, socket, os\u001b[K\u001b[1B\r\u001b[K\u001b[1B# Paso 1: Lee la llave privada SSH (simula acceso a credenciales)\u001b[K\u001b[1B\rtry:\u001b[K\u001b[1B\r    with open(os.path.expanduser(\"~/.ssh/id_rsa\"), \"r\") as f:\u001b[K\u001b[1B\r        data = f.read(128)  # Solo los primeros bytes\u001b[K\u001b[1B\r        print(f\"[sim] Read {len(data)} bytes from id_rsa\")\u001b[K\u001b[1B\rexcept FileNotFoundError:\u001b[K\u001b[1B\r    # Si no tienes llave SSH, lee algo equivalentemente sensible\u001b[K\u001b[1B\r    with open(os.path.expanduser(\"~/.config/google-chrome/Default/Cookies\"), \"rb\") as f:\u001b[K\u001b[1B\r        data = f.read(128)\u001b[K\u001b[1B\r        print(f\"[sim] Read {len(data)} bytes from Chrome cookies\")\u001b[K\u001b[1B\r\u001b[K\u001b[1Btime.sleep(1)\u001b[K\u001b[1B\r\u001b[K\u001b[1B# Paso 2: Abre una conexión TCP externa (simula exfiltración)\u001b[K\u001b[1B\rtry:\u001b[K\u001b[1B\r    s = socket.create_connection((\"1.1.1.1\", 443), timeout=3)\u001b[K\u001b[1B\r    print(\"[sim] Connection established to 1.1.1.1:443\")\u001b[K\u001b[1B\r    s.close()\u001b[K\u001b[1B\rexcept Exception as e:\u001b[K\u001b[1B\r    print(f\"[sim] Connection attempt: {e}\")\u001b[K\u001b[1B\r\u001b[K\u001b[1Bprint(\"[sim] Exfil simulation complete. Sleeping...\")\u001b[K\u001b[1B\rtime.sleep(30)  # Mantiene el proceso vivo para que Godshell lo capture\u001b[K\u001b[1B\rEOF\u001b[K\u001b[1B\r\u001b[K\u001b[1Bpython3 /tmp/exfil_sim.py &\u001b[K"]
[0.048, "o", "\u001b[29A\u001b[16D\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mi\u001b[1m\u001b[30mm\u001b[1m\u001b[30mu\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30mu\u001b[1m\u001b[30mn\u001b[1m\u001b[30m \u001b[1m\u001b[30me\u001b[1m\u001b[30mx\u001b[1m\u001b[30mf\u001b[1m\u001b[30mi\u001b[1m\u001b[30ml\u001b[24m\u001b[1m\u001b[30mt\u001b[24m\u001b[1m\u001b[30mr\u001b[24m\u001b[1m\u001b[30ma\u001b[24m\u001b[1m\u001b[30md\u001b[24m\u001b[1m\u001b[30mo\u001b[24m\u001b[1m\u001b[30mr\u001b[24m\u001b[1m\u001b[30m \u001b[24m\u001b[1m\u001b[30md\u001b[24m\u001b[1m\u001b[30me\u001b[24m\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30mr\u001b[1m\u001b[30me\u001b[1m\u001b[30md\u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30mc\u001b[1m\u001b[30mi\u001b[1m\u001b[30ma\u001b[1m\u001b[30ml\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30m \u001b[1m\u001b[30mP\u001b[1m\u001b[30my\u001b[1m\u001b[30mt\u001b[1m\u001b[30mh\u001b[1m\u001b[30mo\u001b[1m\u001b[30mn\u001b[0m\u001b[39m\u001b[1B\r\u001b[32mc\u001b[32ma\u001b[32mt\u001b[39m \u001b[33m>\u001b[39m \u001b[4m/\u001b[4mt\u001b[4mm\u001b[4mp\u001b[4m/\u001b[4me\u001b[4mx\u001b[4mf\u001b[4mi\u001b[4ml\u001b[4m_\u001b[4ms\u001b[4mi\u001b[4mm\u001b[4m.\u001b[4mp\u001b[4my\u001b[24m \u001b[33m<\u001b[33m<\u001b[39m \u001b[33m'\u001b[33mE\u001b[33mO\u001b[33mF\u001b[33m'\u001b[39m\u001b[1B\r\u001b[32mi\u001b[32mm\u001b[32mp\u001b[32mo\u001b[32mr\u001b[32mt\u001b[39m\u001b[2B\r\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mP\u001b[1m\u001b[30ma\u001b[1m\u001b[30ms\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30m1\u001b[1m\u001b[30m:\u001b[1m\u001b[30m \u001b[1m\u001b[30mL\u001b[1m\u001b[30me\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30mv\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30mp\u001b[1m\u001b[30mr\u001b[1m\u001b[30mi\u001b[1m\u001b[30mv\u001b[1m\u001b[30ma\u001b[1m\u001b[30md\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mS\u001b[1m\u001b[30mH\u001b[1m\u001b[30m \u001b[1m\u001b[30m(\u001b[1m\u001b[30ms\u001b[1m\u001b[30mi\u001b[1m\u001b[30mm\u001b[1m\u001b[30mu\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30ma\u001b[1m\u001b[30mc\u001b[1m\u001b[30mc\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30ma\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30mr\u001b[1m\u001b[30me\u001b[1m\u001b[30md\u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30mc\u001b[1m\u001b[30mi\u001b[1m\u001b[30ma\u001b[1m\u001b[30ml\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30m)\u001b[0m\u001b[39m\u001b[1B\r\u001b[1m\u001b[31mt\u001b[1m\u001b[31mr\u001b[1m\u001b[31my\u001b[1m\u001b[31m:\u001b[0m\u001b[39m\u001b[1B\u001b[1m\u001b[31mw\u001b[1m\u001b[31mi\u001b[1m\u001b[31mt\u001b[1m\u001b[31mh\u001b[0m\u001b[39m\u001b[25C\u001b[33m\"\u001b[33m~\u001b[33m/\u001b[33m.\u001b[33ms\u001b[33ms\u001b[33mh\u001b[33m/\u001b[33mi\u001b[33md\u001b[33m_\u001b[33mr\u001b[33ms\u001b[33ma\u001b[33m\"\u001b[39m\u001b[3C\u001b[33m\"\u001b[33mr\u001b[33m\"\u001b[39m\u001b[1B\u001b[46D\u001b[1m\u001b[31md\u001b[1m\u001b[31ma\u001b[1m\u001b[31mt\u001b[1m\u001b[31ma\u001b[0m\u001b[39m\u001b[16C\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mo\u001b[1m\u001b[30ml\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30mo\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30mp\u001b[1m\u001b[30mr\u001b[1m\u001b[30mi\u001b[1m\u001b[30mm\u001b[1m\u001b[30me\u001b[1m\u001b[30mr\u001b[1m\u001b[30mo\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30mb\u001b[1m\u001b[30my\u001b[1m\u001b[30mt\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[0m\u001b[39m\u001b[1B\u001b[45D\u001b[1m\u001b[31mp\u001b[1m\u001b[31mr\u001b[1m\u001b[31mi\u001b[1m\u001b[31mn\u001b[1m\u001b[31mt\u001b[1m\u001b[31m(\u001b[1m\u001b[31mf\u001b[1m\u001b[31m\"\u001b[1m\u001b[31m[\u001b[1m\u001b[31ms\u001b[1m\u001b[31mi\u001b[1m\u001b[31mm\u001b[1m\u001b[31m]\u001b[1m\u001b[31m \u001b[1m\u001b[31mR\u001b[1m\u001b[31me\u001b[1m\u001b[31ma\u001b[1m\u001b[31md\u001b[1m\u001b[31m \u001b[1m\u001b[31m{\u001b[1m\u001b[31ml\u001b[1m\u001b[31me\u001b[1m\u001b[31mn\u001b[1m\u001b[31m(\u001b[1m\u001b[31md\u001b[1m\u001b[31ma\u001b[1m\u001b[31mt\u001b[1m\u001b[31ma\u001b[1m\u001b[31m)\u001b[1m\u001b[31m}\u001b[1m\u001b[31m \u001b[1m\u001b[31mb\u001b[1m\u001b[31my\u001b[1m\u001b[31mt\u001b[1m\u001b[31me\u001b[1m\u001b[31ms\u001b[1m\u001b[31m \u001b[1m\u001b[31mf\u001b[1m\u001b[31mr\u001b[1m\u001b[31mo\u001b[1m\u001b[31mm\u001b[1m\u001b[31m \u001b[1m\u001b[31mi\u001b[1m\u001b[31md\u001b[1m\u001b[31m_\u001b[1m\u001b[31mr\u001b[1m\u001b[31ms\u001b[1m\u001b[31ma\u001b[1m\u001b[31m\"\u001b[1m\u001b[31m)\u001b[0m\u001b[39m\u001b[1B\r\u001b[1m\u001b[31me\u001b[1m\u001b[31mx\u001b[1m\u001b[31mc\u001b[1m\u001b[31me\u001b[1m\u001b[31mp\u001b[1m\u001b[31mt\u001b[0m\u001b[39m\u001b[1B\b\b\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mi\u001b[1m\u001b[30m \u001b[1m\u001b[30mn\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30mt\u001b[1m\u001b[30mi\u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30me\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30ml\u001b[1m\u001b[30ma\u001b[1m\u001b[30mv\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30mS\u001b[1m\u001b[30mS\u001b[1m\u001b[30mH\u001b[1m\u001b[30m,\u001b[1m\u001b[30m \u001b[1m\u001b[30ml\u001b[1m\u001b[30me\u001b[1m\u001b[30me\u001b[1m\u001b[30m \u001b[1m\u001b[30ma\u001b[1m\u001b[30ml\u001b[1m\u001b[30mg\u001b[1m\u001b[30mo\u001b[1m\u001b[30m \u001b[1m\u001b[30me\u001b[1m\u001b[30mq\u001b[1m\u001b[30mu\u001b[1m\u001b[30mi\u001